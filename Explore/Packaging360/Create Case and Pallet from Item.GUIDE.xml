               <assignment id="a1hDBvyraBz66kh8sZMYXF6O-Assignment62ce66cc-b1e8-48e7-b698-5983eeee2b3f">
                  <title>Enter Packaging Information</title>
                  <operation source="screen" to="temp.tmp_case_gtin">screen.temp.tmp_case_gtin</operation>
                  <operation source="screen" to="temp.tmp_case_description">screen.temp.tmp_case_description</operation>
                  <operation source="screen" to="temp.tmp_case_unit_descriptor_lu">screen.temp.tmp_case_unit_descriptor_lu</operation>
                  <operation source="field" to="temp.tmp_case_includded_each_item">input.in_EachBusinessId</operation>
                  <operation source="formula" to="temp.tmp_casePayload">
                     <expression language="XQuery">'{ "gtin": ' || '"' || $temp.tmp_case_gtin || '"'  ||',
 "description": ' || '"' ||  $temp.tmp_case_description || '"'  ||',
 "included_each_item": { "_businessId": ' || '"' || $input.in_EachBusinessId || '"'  ||'},
 "unit_descriptor": { "Code":' || '"' || $temp.tmp_case_unit_descriptor_lu || '"'  ||' , "Name": "Case"}
}'</expression>
                  </operation>
                  <operation source="screen" to="temp.tmp_pallet_gtin">screen.temp.tmp_pallet_gtin</operation>
                  <operation source="screen" to="temp.tmp_pallet_title">screen.temp.tmp_pallet_title</operation>
                  <operation source="screen" to="temp.tmp_pallet_hi">screen.temp.tmp_pallet_hi</operation>
                  <operation source="screen" to="temp.tmp_pallet_ti">screen.temp.tmp_pallet_ti</operation>
                  <operation source="screen" to="temp.tmp_pallet_isStackable">screen.temp.tmp_pallet_isStackable</operation>
                  <operation source="constant" to="temp.tmp_palletUnitType">pallet</operation>
                  <operation source="screen" to="temp.tmp_StackCount">screen.temp.tmp_StackCount</operation>
                  <operation source="formula" to="temp.tmp_palletPayLoad">
                     <expression language="XQuery">'{ 
  "pallet_id": ' || '"' || $temp.tmp_pallet_gtin || '"'  ||',
  "pallet_hi": ' || '"' ||  $temp.tmp_pallet_hi || '"'  ||',
  "pallet_ti": ' || '"' ||  $temp.tmp_pallet_ti || '"'  ||',
  "title": ' || '"' ||  $temp.tmp_pallet_title || '"'  ||',
  "stack_count": ' || $temp.tmp_StackCount ||',
