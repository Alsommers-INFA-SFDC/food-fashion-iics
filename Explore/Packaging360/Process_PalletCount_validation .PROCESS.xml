               <assignment id="a172ZIwiN13Vrjnmrt7UVXyN-Assignment0875bebd-449d-4de4-935c-5d2e2860610c">
                  <title>Assignment to temp_shipping_package_res, op_shipping_packaging_total_units</title>
                  <operation source="field" to="temp.temp_shipping_package_res">output.beRecord</operation>
                  <operation source="formula" to="output.op_shipping_packaging_total_units">
                     <expression language="XQuery">util:toInteger($temp.temp_shipping_package_res/total_consumer_units_in_pack)</expression>
                  </operation>
                  <operation source="formula" to="output.item_ID">
                     <expression language="XQuery">$temp.temp_shipping_package_res/included_each_item/businessId</expression>
                  </operation>
                  <link id="zee264d45-1399-4738-b46c-35ae49a65f33"
                        targetId="a172ZIwiN13Vrjnmrt7UVXyN-Assignmentc1cc62f9-da00-4fae-8e4c-f00f91d18131"/>
               </assignment>
               <assignment id="a172ZIwiN13Vrjnmrt7UVXyN-Assignmentc1cc62f9-da00-4fae-8e4c-f00f91d18131">
                  <title>Assignment to op_total_item_calc, IsValid</title>
                  <operation source="formula" to="output.op_total_item_calc">
                     <expression language="XQuery">$output.op_pallet_HI* $output.op_pallet_TI* $output.op_shipping_packaging_total_units</expression>
                  </operation>
                  <operation source="formula" to="output.IsValid_exp">
                     <expression language="XQuery">util:iif(xs:int( $output.op_total_item_calc ) = xs:int( $input.ip_total_count_pallet ), "Valid", "Invalid")</expression>
                  </operation>
                  <link id="tb0b4b985-2d60-4033-964f-6b46f690f87f"
                        targetId="a172ZIwiN13Vrjnmrt7UVXyN-Assignment539f0b74-5d21-414d-9df9-a56ec080f378"/>
               </assignment>
               <assignment id="a172ZIwiN13Vrjnmrt7UVXyN-Assignment539f0b74-5d21-414d-9df9-a56ec080f378">
                  <title>Assignment to update_payload, validation_field_msg</title>
                  <operation source="formula" to="output.validation_field_msg">
                     <expression language="XQuery">util:iif ( $output.IsValid_exp = 'Valid' , $output.IsValid_exp , $output.IsValid_exp ||' - Expected: ' || string($output.op_total_item_calc) )</expression>
                  </operation>
                  <operation source="formula" to="output.update_payload">
                     <expression language="XQuery">let $op := '[{ "op": "replace", "path": "validation_rule_count_of_total_product_is_accurate", "value": ' || '"' ||  $output.validation_field_msg || '"'  ||'}]'

return $op</expression>
                  </operation>
                  <link id="nc713d5a3-8463-4bb2-905b-b5108c905a7c"
                        targetId="a172ZIwiN13Vrjnmrt7UVXyN-end-qaddc9775-847a-45cf-9e62-ef22b3eb18c0"/>
               </assignment>
