               <assignment id="a172ZIwiN13Vrjnmrt7UVXyN-Assignment138a0bd0-0689-4130-b201-528d21d25edc">
                  <title>Assignment to temp_pallet_res, op_pallet_child_ID, etc,</title>
                  <operation source="field" to="temp.temp_pallet_res">output.beRecord</operation>
                  <operation source="formula" to="output.op_pallet_child_ID">
                     <expression language="XQuery">$temp.temp_pallet_res/child_gtin/businessId</expression>
                  </operation>
                  <operation source="formula" to="output.op_pallet_count_of_case">
                     <expression language="XQuery">util:iif(util:isNull($temp.temp_pallet_res/count_of_case), -1, $temp.temp_pallet_res/count_of_case)</expression>
                  </operation>
                  <operation source="formula" to="output.op_pallet_total_count_of_each">
                     <expression language="XQuery">util:iif(util:isNull($temp.temp_pallet_res/total_count_of_each), -1, $temp.temp_pallet_res/total_count_of_each)</expression>
                  </operation>
                  <operation source="formula" to="output.op_pallet_TI">
                     <expression language="XQuery">util:iif(util:isNull($temp.temp_pallet_res/pallet_ti), -1, $temp.temp_pallet_res/pallet_ti)</expression>
                  </operation>
                  <operation source="formula" to="output.op_pallet_HI">
                     <expression language="XQuery">util:iif(util:isNull($temp.temp_pallet_res/pallet_hi), -1, $temp.temp_pallet_res/pallet_hi)</expression>
                  </operation>
                  <link id="ld9be2a5c-4f98-414a-9f44-0654606dd1e2"
