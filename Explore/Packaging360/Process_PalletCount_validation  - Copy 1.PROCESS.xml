                  <title>Assignment to op_total_item_calc, IsValid</title>
                  <operation source="formula" to="output.op_total_item_calc">
                     <expression language="XQuery">$output.op_pallet_HI* $output.op_pallet_TI* $output.op_shipping_packaging_total_units</expression>
                  </operation>
                  <operation source="formula" to="output.IsValid">
                     <expression language="XQuery">util:iif(xs:int( $output.op_total_item_calc ) = xs:int( $output.op_pallet_total_count_of_each ), "Valid", "Invalid")</expression>
                  </operation>
                  <link id="i64c4f259-a3d6-41d8-a80b-e72a975e3d78"
