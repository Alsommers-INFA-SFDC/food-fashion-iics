               <assignment id="a14QstRXAivZPkORo2fqEDe6-Assignmentaba14641-6970-4c13-bb50-319239094ac6">
                  <title>Assignment to tmp_postHierarchyBody, in_toBusinessId, etc,</title>
                  <operation source="formula" to="temp.temp_toBusinessID_raw">
                     <expression language="XQuery">if (empty( $output.productType )) then
  $output.productCategory 
else
  $output.productType 
</expression>
                  </operation>
                  <operation source="formula" to="input.in_toBusinessId">
                     <expression language="XQuery">replace(
replace(
replace ($temp.temp_toBusinessID_raw , " &amp;amp; ", '_')
,' ', '_')
,'-','')</expression>
                  </operation>
                  <operation source="formula" to="temp.tmp_postHierarchyBody">
                     <expression language="XQuery">let $fromEntity := $input.in_fromEntityType 
let $fromId := $input.in_fromBusinessId 
let $toEntity := $input.in_toEntityType 
let $toId := $input.in_toBusinessId
return
  concat(
    '{',
      '"_from": {',
        '"businessEntity": "', $input.in_fromEntityType , '", ',
        '"businessId": "', $input.in_fromBusinessId , '"',
      '}, ',
      '"_to": {',
        '"businessEntity": "', $input.in_toEntityType , '", ',
        '"businessId": "', $input.in_toBusinessId , '"',
      '}',
    '}'
  )
</expression>
                  </operation>
                  <operation source="field" to="output.o_CategoryName">temp.temp_toBusinessID_raw</operation>
                  <operation source="field" to="output.o_hierarchyBody">temp.tmp_postHierarchyBody</operation>
